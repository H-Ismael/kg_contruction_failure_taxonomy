              {
                "id": "boundary_error",
                "failure_mode": "Extracts partial or oversized mention",
                "typical_causes": [
                  "punctuation ambiguity",
                  "nested entities",
                  "tokenization artifacts",
                  "domain-specific naming patterns"
                ],
                "impact": [
                  "wrong node creation",
                  "failed entity linking",
                  "relation attachment errors"
                ],
                "mitigations": [
                  "boundary rules",
                  "span overlap resolution",
                  "domain gazetteers",
                  "candidate span reranking"
                ],
                "llm_usage": {
                  "recommended_role": "candidate_generator_or_reranker",
                  "risks": [
                    "free-form span drift",
                    "inconsistent boundaries"
                  ]
                },
                "validation": [
                  "exact span match",
                  "partial span match",
                  "human audit on ambiguous spans"
                ]
              },
              {
                "id": "missed_mention",
                "failure_mode": "Entity mention not extracted",
                "typical_causes": [
                  "unseen jargon",
                  "noisy text",
                  "weak recall thresholds"
                ],
                "impact": [
                  "missing nodes",
                  "missing edges",
                  "broken coreference chains"
                ],
                "mitigations": [
                  "recall-oriented extraction pass",
                  "gazetteer augmentation",
                  "fuzzy lookup",
                  "chunk overlap"
                ],
                "llm_usage": {
                  "recommended_role": "long_tail_candidate_recovery",
                  "risks": [
                    "hallucinated mentions"
                  ]
                },
                "validation": [
                  "mention recall"
                ]
              },
              {
                "id": "spurious_mention",
                "failure_mode": "Non-entity extracted as entity",
                "typical_causes": [
                  "capitalization bias",
                  "overgeneralization",
                  "weak type constraints"
                ],
                "impact": [
                  "graph pollution",
                  "bad candidate links"
                ],
                "mitigations": [
                  "type-aware filtering",
                  "blacklist patterns",
                  "confidence thresholding"
                ],
                "llm_usage": {
                  "recommended_role": "semantic_filter",
                  "risks": [
                    "false semantic confidence"
                  ]
                },
                "validation": [
                  "precision",
                  "false positive review"
